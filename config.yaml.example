# ============================================================
# 跨市场量比监控系统 - 配置示例文件
# ============================================================
# 复制此文件为 config.yaml 并填入实际值
# 敏感信息（api_key、app_secret）不要提交到代码仓库
# 修改后自动热加载，无需重启进程
# ============================================================

# ------------------------------------------------------------
# 一、监控标的（必填）
# ------------------------------------------------------------
# 格式: 股票代码.市场-中文名
watchlist:
  us:
    - NVDL.US-英伟达2x
    - MUU.US-美光2x
    - CLF.US-克利夫兰
    - BMNR.US-BitMine
    - DRAM.US-美光HBM
    - NVO.US-诺和诺德
  hk:
    - 1810.HK-小米集团
    - 700.HK-腾讯控股
    - 9988.HK-阿里巴巴
  cn:
    - 601899.SH-紫金矿业
    - 603308.SH-应流股份

# ------------------------------------------------------------
# 二、系统参数
# ------------------------------------------------------------
params:
  volume_ratio_window: 5              # 历史同期量比：过去 N 个交易日
  intraday_signal_window_minutes: 5   # 日内滚动量比：最近 W 分钟
  intraday_baseline_minutes: 30       # 日内滚动量比：前 B 分钟基线
  intraday_baseline_method: mean      # mean / median
  intraday_alert_threshold: 1.5
  alert_threshold: 2.0
  shrink_threshold: 0.6

# ------------------------------------------------------------
# 三、LLM 配置
# ------------------------------------------------------------
# 使用命令切换模型：python3 scripts/llm.py --switch minimax
llm:
  provider: "xiaomi"
  model: "mimo-v2.5-pro"
  base_url: "https://token-plan-cn.xiaomimimo.com/anthropic"
  api_key: "YOUR_API_KEY_HERE"
  max_tokens: 800
  temperature: 0.3

llm_profiles:
  minimax:
    provider: "minimax"
    model: "MiniMax-M2.7"
    base_url: "https://api.minimaxi.com/anthropic"
    api_key: "YOUR_MINIMAX_API_KEY"

  xiaomi:
    provider: "xiaomi"
    model: "mimo-v2.5-pro"
    base_url: "https://token-plan-cn.xiaomimimo.com/anthropic"
    api_key: "YOUR_XIAOMI_API_KEY"

# ------------------------------------------------------------
# 四、飞书配置（可选）
# ------------------------------------------------------------
# 配置后可同时通过飞书接收告警通知（桌面客户端 + 飞书双通道）
# 不配置则仅通过桌面客户端接收通知，不影响正常使用
# 方式一：自建应用（推荐，支持交互指令和富文本卡片）
# feishu:
#   app_id: "YOUR_APP_ID"
#   app_secret: "YOUR_APP_SECRET"
#   chat_id: "YOUR_CHAT_ID"
#   # webhook_url 保留作为备用（自建应用模式下可选）
#   # webhook_url: "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN"

# ------------------------------------------------------------
# 五、桌面客户端 API 配置
# ------------------------------------------------------------
api:
  host: "127.0.0.1"    # API 监听地址（仅本地访问）
  port: 9720            # API 端口
